{% comment %}
  Puanlarım — Sadakat Sistemi Müşteri Bloğu
  Shopify Online Store 2.0 Theme App Extension
{% endcomment %}

<div
  id="loyalty-root"
  data-logged-in="{% if customer %}true{% else %}false{% endif %}"
  data-customer-id="{{ customer.id }}"
  data-proxy-url="/apps/{{ block.settings.proxy_subpath }}"
  data-api-override="{{ block.settings.api_url_override | strip }}"
  style="
    --lp-green: {{ block.settings.color_header_bg }};
    --lp-green-text: {{ block.settings.color_header_text }};
    --lp-cream: {{ block.settings.color_app_bg }};
    --lp-cream-border: {{ block.settings.color_app_border }};
    --lp-teal: {{ block.settings.color_accent }};
    --lp-teal-dark: {{ block.settings.color_accent_dark }};
    --lp-orange: {{ block.settings.color_highlight }};
  "
>

  {%- if customer == blank -%}
    <!-- ── GİRİŞ KAPISI ── -->
    <div class="lp-gate">
      <div class="lp-gate__card">
        <div class="lp-gate__icon">{% comment %}icon{% endcomment %}
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
        </div>
        <h2 class="lp-gate__title">{{ block.settings.gate_title }}</h2>
        <p class="lp-gate__desc">{{ block.settings.gate_desc }}</p>
        <a
          href="{{ routes.account_login_url }}?return_to={{ request.path | url_encode }}"
          class="lp-btn lp-btn--primary lp-btn--lg"
        >
          {{ block.settings.gate_btn }}
        </a>
      </div>
    </div>

  {%- else -%}
    <!-- Liquid: Metafield verisini JS'e göm (proxy'ye gerek yok) -->
    {%- assign lf = customer.metafields.app.loyalty_data -%}
    <script>
      window.__LP__ = {%- if lf and lf.value -%}{{ lf.value | json }}{%- else -%}null{%- endif -%};
    </script>

    <!-- ── ANA UYGULAMA ── -->
    <div id="loyalty-app" class="lp-app" aria-live="polite">

      <!-- İstatistik Tablosu -->
      <div class="lp-stats-table">
        <div class="lp-stats-header">
          <div class="lp-stats-h">
            {% render 'lp-icon-medal' %}
            <span>{{ block.settings.label_earned }}</span>
          </div>
          <div class="lp-stats-h">
            <span>{{ block.settings.label_spent }}</span>
          </div>
          <div class="lp-stats-h">
            {% render 'lp-icon-medal' %}
            <span>{{ block.settings.label_current }}</span>
          </div>
        </div>
        <div class="lp-stats-values">
          <div class="lp-stats-v">
            <span id="lp-total-earned" class="lp-skeleton lp-skeleton--value"></span>
            {% render 'lp-icon-coin' %}
          </div>
          <div class="lp-stats-v lp-stats-v--muted">
            <span id="lp-total-spent" class="lp-skeleton lp-skeleton--value"></span>
            {% render 'lp-icon-coin' %}
          </div>
          <div class="lp-stats-v lp-stats-v--accent">
            <span id="lp-current-points" class="lp-skeleton lp-skeleton--value"></span>
            {% render 'lp-icon-coin' %}
          </div>
        </div>
      </div>

      <!-- İndirim Kuponu Oluştur -->
      <div class="lp-create">
        <div class="lp-create__info">
          <h3 class="lp-create__title">
            {% render 'lp-icon-ticket' %}
            {{ block.settings.create_title }}
          </h3>
          <p class="lp-create__desc">{{ block.settings.create_desc }}</p>
        </div>
        <div class="lp-create__action">
          <button
            class="lp-btn lp-btn--primary lp-btn--create"
            id="lp-open-convert"
            disabled
            aria-disabled="true"
            data-label="{{ block.settings.btn_convert | escape }}"
          >
            {{ block.settings.btn_convert }}
          </button>
          <div class="lp-code-display" id="lp-code-display">
            <span class="lp-code-display__value" id="lp-code-display-value">— — — — — — — —</span>
            <button class="lp-copy-btn" id="lp-copy-generated" hidden title="Kodu Kopyala" aria-label="Kodu Kopyala">
              {% render 'lp-icon-copy' %}
            </button>
          </div>
        </div>
        <div class="lp-create__note">
          {% render 'lp-icon-info' %}
          <span>{{ block.settings.create_note }}</span>
        </div>
      </div>

      <!-- Kupon Dönüştür Modal -->
      <div
        id="lp-modal"
        class="lp-modal"
        role="dialog"
        aria-modal="true"
        aria-labelledby="lp-modal-title"
        hidden
      >
        <div class="lp-modal__backdrop" id="lp-modal-backdrop"></div>
        <div class="lp-modal__card">
          <h3 class="lp-modal__title" id="lp-modal-title">{{ block.settings.modal_title }}</h3>
          <p class="lp-modal__desc">{{ block.settings.modal_desc }}</p>
          <p class="lp-modal__balance">
            Mevcut puanınız: <strong id="lp-modal-balance">0</strong>
          </p>
          <input
            type="number"
            id="lp-convert-amount"
            class="lp-input"
            min="1"
            step="1"
            placeholder="Miktar girin"
            aria-label="Dönüştürülecek puan miktarı"
          />
          <p class="lp-modal__note">{{ block.settings.modal_note }}</p>
          <div class="lp-modal__actions">
            <button class="lp-btn lp-btn--ghost" id="lp-modal-cancel">
              İptal
            </button>
            <button
              class="lp-btn lp-btn--primary"
              id="lp-modal-confirm"
              data-label="{{ block.settings.modal_confirm | escape }}"
            >
              {{ block.settings.modal_confirm }}
            </button>
          </div>
        </div>
      </div>

      <!-- Geçmiş Kuponlarım -->
      <div class="lp-history">
        <h3 class="lp-history__title">
          {% render 'lp-icon-history' %}
          {{ block.settings.coupons_title }}
        </h3>
        <div id="lp-coupons-list" data-empty="{{ block.settings.coupons_empty | escape }}"></div>
      </div>

    </div>

    <!-- Toast bildirimi -->
    <div id="lp-toast-container" aria-live="polite" aria-atomic="true"></div>

  {%- endif -%}
</div>

<!-- ══════════════════════════════════════════════
     STILLER
══════════════════════════════════════════════ -->
<style>
  #loyalty-root {
    --lp-text: var(--color-foreground, var(--color-text, #1a1a1a));
    --lp-text-sub: color-mix(in srgb, var(--lp-text) 55%, transparent);
    --lp-bg: var(--color-background, #fff);
    --lp-surface: color-mix(in srgb, var(--lp-text) 4%, var(--lp-bg));
    --lp-border: color-mix(in srgb, var(--lp-text) 12%, transparent);
    --lp-accent: var(--color-button, var(--color-accent, #1a1a1a));
    --lp-accent-text: var(--color-button-text, var(--color-background, #fff));
    --lp-radius: 16px;
    --lp-radius-sm: 10px;
    --lp-shadow: 0 2px 16px rgba(0,0,0,.07), 0 1px 3px rgba(0,0,0,.06);
    --lp-shadow-hover: 0 8px 32px rgba(0,0,0,.12), 0 2px 8px rgba(0,0,0,.08);
    --lp-transition: 0.2s ease;

    /* ── Kutu Oyunu AI tema renkleri ── */
    --lp-green: #dfe9d8;
    --lp-green-text: #355a3c;
    --lp-cream: #fbf2de;
    --lp-cream-border: #f1e1bf;
    --lp-teal: #2f5c56;
    --lp-teal-dark: #244a45;
    --lp-orange: #efa23c;
    --lp-status-active: #3fa56b;
    --lp-status-used: #efa23c;
    --lp-status-expired: #9a9a9a;

    font-family: inherit;
    color: var(--lp-text);
  }

  /* ── Giriş Kapısı ── */
  .lp-gate {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 60px 16px;
  }
  .lp-gate__card {
    background: var(--lp-bg);
    border: 1px solid var(--lp-border);
    border-radius: var(--lp-radius);
    box-shadow: var(--lp-shadow);
    padding: 48px 40px;
    text-align: center;
    max-width: 420px;
    width: 100%;
  }
  .lp-gate__icon {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    width: 72px;
    height: 72px;
    background: var(--lp-surface);
    border-radius: 50%;
    margin-bottom: 20px;
    color: var(--lp-text-sub);
  }
  .lp-gate__title {
    margin: 0 0 10px;
    font-size: 20px;
    font-weight: 700;
    color: var(--lp-text);
  }
  .lp-gate__desc {
    margin: 0 0 28px;
    font-size: 14px;
    line-height: 1.6;
    color: var(--lp-text-sub);
  }

  /* ── Butonlar ── */
  .lp-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 10px 20px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    border: none;
    outline: none;
    transition: opacity var(--lp-transition), transform var(--lp-transition), box-shadow var(--lp-transition);
    text-decoration: none;
    white-space: nowrap;
  }
  .lp-btn--primary {
    background: var(--lp-teal);
    color: #fff;
  }
  .lp-btn--primary:hover:not(:disabled) {
    opacity: .9;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(0,0,0,.15);
  }
  .lp-btn--primary:active:not(:disabled) {
    transform: translateY(0);
  }
  .lp-btn--ghost {
    background: transparent;
    color: var(--lp-text-sub);
    border: 1px solid var(--lp-border);
  }
  .lp-btn--ghost:hover {
    background: var(--lp-surface);
  }
  .lp-btn--lg {
    padding: 13px 32px;
    font-size: 15px;
    border-radius: 10px;
  }
  .lp-btn:disabled {
    opacity: .4;
    cursor: not-allowed;
  }
  .lp-btn--create {
    padding: 13px 22px;
    border-radius: 10px;
    font-size: 14px;
    flex-shrink: 0;
  }

  /* ── Ana Uygulama ── */
  .lp-app {
    padding: 24px;
    background: var(--lp-cream);
    border: 1px solid var(--lp-cream-border);
    border-radius: var(--lp-radius);
  }

  /* ── İstatistik Tablosu ── */
  .lp-stats-table {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border: 1px solid var(--lp-cream-border);
    border-radius: var(--lp-radius-sm);
    overflow: hidden;
    margin-bottom: 24px;
    background: var(--lp-bg);
  }
  .lp-stats-header,
  .lp-stats-values {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-column: 1 / -1;
  }

  .lp-stats-h {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 12px;
    background: var(--lp-green);
    color: var(--lp-green-text);
    font-size: 13px;
    font-weight: 700;
    text-align: center;
    border-right: 1px solid var(--lp-cream-border);
    border-bottom: 1px solid var(--lp-cream-border);
  }
  .lp-stats-h svg { flex-shrink: 0; width: 18px; height: 18px; }
  .lp-stats-header .lp-stats-h:last-child { border-right: none; }

  .lp-stats-v {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 22px 12px;
    background: var(--lp-cream);
    font-size: 26px;
    font-weight: 800;
    color: var(--lp-text);
    border-right: 1px solid var(--lp-cream-border);
  }
  .lp-stats-values .lp-stats-v:last-child { border-right: none; }
  .lp-stats-v svg { flex-shrink: 0; width: 22px; height: 22px; }
  .lp-stats-v--muted {
    color: var(--lp-text-sub);
    text-decoration: line-through;
  }
  .lp-stats-v--accent { color: var(--lp-teal); }

  /* ── İndirim Kuponu Oluştur ── */
  .lp-create {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 16px 24px;
    background: var(--lp-bg);
    border: 1px solid var(--lp-cream-border);
    border-radius: var(--lp-radius-sm);
    padding: 22px 24px;
    margin-bottom: 18px;
  }
  .lp-create__title {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0 0 8px;
    font-size: 17px;
    font-weight: 700;
    color: var(--lp-teal);
  }
  .lp-create__title svg { flex-shrink: 0; width: 22px; height: 22px; color: var(--lp-orange); }
  .lp-create__desc {
    margin: 0;
    font-size: 13px;
    line-height: 1.6;
    color: var(--lp-text-sub);
    max-width: 480px;
  }
  .lp-create__action {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }
  .lp-code-display {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    min-width: 180px;
    padding: 11px 16px;
    background: var(--lp-teal);
    color: #fff;
    border-radius: var(--lp-radius-sm);
  }
  .lp-code-display__value {
    font-family: ui-monospace, 'Cascadia Code', 'Courier New', monospace;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: .1em;
    color: rgba(255,255,255,.6);
  }
  .lp-code-display--filled .lp-code-display__value { color: #fff; }
  .lp-code-display .lp-copy-btn {
    border-color: rgba(255,255,255,.3);
    background: rgba(255,255,255,.12);
    color: #fff;
  }
  .lp-code-display .lp-copy-btn:hover { background: rgba(255,255,255,.22); }

  .lp-create__note {
    grid-column: 1 / -1;
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 12px 16px;
    background: var(--lp-surface);
    border-radius: var(--lp-radius-sm);
    font-size: 12px;
    line-height: 1.6;
    color: var(--lp-text-sub);
  }
  .lp-create__note svg { flex-shrink: 0; width: 16px; height: 16px; margin-top: 1px; }
  .lp-create__note strong { color: var(--lp-text); }

  /* ── Skeleton Loading ── */
  @keyframes lp-shimmer {
    0%   { background-position: -400px 0; }
    100% { background-position: 400px 0; }
  }
  .lp-skeleton {
    display: inline-block;
    border-radius: 6px;
    background: linear-gradient(90deg, var(--lp-border) 25%, color-mix(in srgb, var(--lp-border) 50%, var(--lp-bg)) 50%, var(--lp-border) 75%);
    background-size: 400px 100%;
    animation: lp-shimmer 1.4s ease infinite;
  }
  .lp-skeleton--value  { width: 70px; height: 30px; }
  .lp-skeleton--code   { width: 140px; height: 18px; }

  /* ── Modal ── */
  .lp-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
  }
  .lp-modal[hidden] { display: none; }
  .lp-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,.45);
    backdrop-filter: blur(4px);
  }
  .lp-modal__card {
    position: relative;
    background: var(--lp-bg);
    border-radius: var(--lp-radius);
    box-shadow: 0 24px 64px rgba(0,0,0,.2);
    padding: 36px;
    width: 100%;
    max-width: 420px;
    animation: lp-modal-in .18s ease;
  }
  @keyframes lp-modal-in {
    from { opacity: 0; transform: scale(.96) translateY(8px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }
  .lp-modal__title {
    margin: 0 0 8px;
    font-size: 18px;
    font-weight: 700;
  }
  .lp-modal__desc {
    margin: 0 0 14px;
    font-size: 14px;
    color: var(--lp-text-sub);
    line-height: 1.5;
  }
  .lp-modal__balance {
    margin: 0 0 16px;
    font-size: 13px;
    color: var(--lp-text-sub);
  }
  .lp-modal__note {
    margin: 6px 0 24px;
    font-size: 12px;
    color: var(--lp-text-sub);
  }
  .lp-modal__actions {
    display: flex;
    gap: 10px;
    justify-content: flex-end;
  }

  /* ── Input ── */
  .lp-input {
    width: 100%;
    box-sizing: border-box;
    padding: 11px 14px;
    border: 1px solid var(--lp-border);
    border-radius: var(--lp-radius-sm);
    background: var(--lp-surface);
    color: var(--lp-text);
    font-family: inherit;
    font-size: 15px;
    font-weight: 600;
    outline: none;
    transition: border-color var(--lp-transition), box-shadow var(--lp-transition);
  }
  .lp-input:focus {
    border-color: var(--lp-teal);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--lp-teal) 18%, transparent);
  }

  /* ── Geçmiş Kuponlarım ── */
  .lp-history__title {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0 0 14px;
    font-size: 16px;
    font-weight: 700;
    color: var(--lp-teal);
  }
  .lp-history__title svg { flex-shrink: 0; width: 20px; height: 20px; color: var(--lp-orange); }
  #lp-coupons-list { display: flex; flex-direction: column; gap: 12px; }

  .lp-coupon-row {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    gap: 12px 20px;
    background: var(--lp-teal);
    color: #fff;
    border-radius: var(--lp-radius-sm);
    padding: 18px 22px;
    transition: box-shadow var(--lp-transition);
  }
  .lp-coupon-row:hover { box-shadow: var(--lp-shadow-hover); }
  .lp-coupon-row--skeleton { pointer-events: none; opacity: .6; }

  .lp-coupon-points {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 22px;
    font-weight: 800;
  }
  .lp-coupon-points svg { flex-shrink: 0; width: 22px; height: 22px; color: var(--lp-orange); }

  .lp-coupon-mid {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    font-size: 13px;
    color: rgba(255,255,255,.75);
  }
  .lp-coupon-mid strong {
    font-size: 15px;
    font-weight: 700;
    color: #fff;
  }
  .lp-coupon-code {
    font-family: ui-monospace, 'Cascadia Code', 'Courier New', monospace;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .04em;
    color: #fff;
    background: rgba(255,255,255,.12);
    padding: 3px 8px;
    border-radius: 6px;
  }

  .lp-coupon-date {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 500;
    color: rgba(255,255,255,.7);
    white-space: nowrap;
  }
  .lp-coupon-date svg { flex-shrink: 0; width: 14px; height: 14px; }

  .lp-coupon-status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: 99px;
    font-size: 12px;
    font-weight: 700;
    white-space: nowrap;
  }
  .lp-coupon-status svg { width: 14px; height: 14px; }
  .lp-status--active  { background: var(--lp-status-active); color: #fff; }
  .lp-status--used    { background: var(--lp-status-used); color: #fff; }
  .lp-status--expired { background: var(--lp-status-expired); color: #fff; }

  .lp-copy-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: 1px solid var(--lp-border);
    border-radius: 8px;
    background: var(--lp-surface);
    color: var(--lp-text-sub);
    cursor: pointer;
    transition: background var(--lp-transition), color var(--lp-transition), border-color var(--lp-transition);
    flex-shrink: 0;
  }
  .lp-copy-btn:hover { background: var(--lp-border); color: var(--lp-text); }
  .lp-copy-btn--copied {
    background: #16a34a !important;
    border-color: #16a34a !important;
    color: #fff !important;
  }

  .lp-empty {
    text-align: center;
    padding: 40px 20px;
    color: var(--lp-text-sub);
    font-size: 14px;
    background: var(--lp-bg);
    border-radius: var(--lp-radius-sm);
    border: 1px dashed var(--lp-cream-border);
  }

  /* ── Toast ── */
  #lp-toast-container {
    position: fixed;
    bottom: 28px;
    right: 24px;
    z-index: 10000;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .lp-toast {
    padding: 12px 18px;
    border-radius: 10px;
    font-size: 13px;
    font-weight: 600;
    box-shadow: 0 8px 24px rgba(0,0,0,.15);
    animation: lp-toast-in .2s ease;
    max-width: 320px;
  }
  @keyframes lp-toast-in {
    from { opacity: 0; transform: translateY(10px) scale(.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
  .lp-toast--success { background: #16a34a; color: #fff; }
  .lp-toast--error   { background: #dc2626; color: #fff; }
  .lp-toast--info    { background: var(--lp-teal); color: #fff; }

  @media (max-width: 720px) {
    .lp-stats-table { grid-template-columns: 1fr; }
    .lp-stats-header, .lp-stats-values { grid-template-columns: 1fr; }
    .lp-stats-h, .lp-stats-v {
      border-right: none;
      border-bottom: 1px solid var(--lp-cream-border);
    }
    .lp-stats-values .lp-stats-v:last-child,
    .lp-stats-header .lp-stats-h:last-child { border-bottom: none; }

    .lp-create { grid-template-columns: 1fr; }
    .lp-create__action { justify-content: stretch; }
    .lp-create__action .lp-btn--create { width: 100%; }
    .lp-code-display { width: 100%; }

    .lp-coupon-row {
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto auto;
    }
    .lp-coupon-mid { grid-column: 1 / -1; order: 3; }
    .lp-gate__card { padding: 36px 24px; }
  }
</style>

<!-- ══════════════════════════════════════════════
     JAVASCRIPT
══════════════════════════════════════════════ -->
<script>
(function () {
  var root = document.getElementById('loyalty-root');
  if (!root) return;

    var isLoggedIn = root.dataset.loggedIn === 'true';
    if (!isLoggedIn) return;

    // FETCH_URL: use direct override if merchant provided one, otherwise use App Proxy
    var PROXY_URL = root.dataset.proxyUrl || '/apps/loyalty';
    var apiOverride = root.dataset.apiOverride || '';
    var FETCH_URL = apiOverride || PROXY_URL;

    var confirmBtnRef = document.getElementById('lp-modal-confirm');
    var CONFIRM_LABEL = (confirmBtnRef && confirmBtnRef.dataset.label) || 'Kuponu Oluştur';

  // ── Yardımcı Fonksiyonlar ──────────────────────────
  function fmtPoints(n) {
    return Math.floor(Number(n) || 0).toLocaleString('tr-TR');
  }

  function fmtCurrency(n) {
    return new Intl.NumberFormat('tr-TR', {
      style: 'currency',
      currency: 'TRY',
      minimumFractionDigits: 2,
      maximumFractionDigits: 2,
    }).format(Number(n) || 0);
  }

  function fmtDate(iso) {
    return new Intl.DateTimeFormat('tr-TR', { dateStyle: 'short' }).format(new Date(iso));
  }

  function showToast(msg, type) {
    type = type || 'info';
    var container = document.getElementById('lp-toast-container');
    var toast = document.createElement('div');
    toast.className = 'lp-toast lp-toast--' + type;
    toast.textContent = msg;
    container.appendChild(toast);
    setTimeout(function () {
      toast.style.opacity = '0';
      toast.style.transform = 'translateY(8px)';
      toast.style.transition = 'all .2s ease';
      setTimeout(function () { toast.remove(); }, 220);
    }, 3200);
  }

  // ── Veri Çekme ─────────────────────────────────────
  var loyaltyData = null;

  /**
   * Robust fetch: handles non-JSON responses (HTML error pages, 4xx/5xx)
   * and gives actionable error messages for common proxy misconfigurations.
   */
  function fetchData() {
    var url = FETCH_URL;

    return fetch(url, {
      headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
    })
      .then(function (r) {
        var ct = r.headers.get('content-type') || '';

        // Server returned non-JSON (likely HTML error page or proxy misconfiguration)
        if (!ct.includes('application/json')) {
          return r.text().then(function (body) {
            console.error('[Loyalty] Non-JSON response body (first 300 chars):', body.slice(0, 300));
            var hint = '';
            if (r.status === 404) {
              hint = 'App Proxy URL yapılandırılmamış veya yanlış. shopify.app.toml → [app_proxy] url değerini kontrol edin.';
            } else if (r.status === 400 || r.status === 401) {
              hint = 'Proxy kimlik doğrulaması başarısız (HMAC geçersiz). Uygulamanın doğru URL\'de çalıştığından emin olun.';
            } else if (r.status === 503 || r.status === 502) {
              hint = 'Uygulama sunucusuna ulaşılamıyor. Uygulamanın çalışır durumda olduğunu kontrol edin.';
            } else {
              hint = 'Proxy URL\'si "example.com" ise shopify.app.toml\'u gerçek URL ile güncelleyip tekrar deploy edin.';
            }
            throw new Error('HTTP ' + r.status + ': ' + hint);
          });
        }

        return r.json().then(function (json) {
          if (!r.ok) {
            throw new Error(json.error || 'Sunucu hatası: HTTP ' + r.status);
          }
          return json;
        });
      })
      .then(function (json) {
        if (json.success) {
          loyaltyData = json.data;
          renderApp();
        } else {
          showError(json.error || 'Veri yüklenemedi.');
        }
      })
      .catch(function (err) {
        console.error('[Loyalty] Fetch failed:', err);
        showError(err.message || 'Bağlantı hatası oluştu. Konsolu kontrol edin.');
      });
  }

  function showError(msg) {
    var app = document.getElementById('loyalty-app');
    if (!app) return;
    app.innerHTML =
      '<div style="padding:32px 24px;text-align:center;">' +
        '<p style="color:var(--lp-text-sub);font-size:14px;line-height:1.6;margin:0 0 12px;">' +
        escHtml(msg) +
        '</p>' +
        '<button onclick="window.location.reload()" style="' +
          'padding:8px 18px;border-radius:8px;border:1px solid var(--lp-border);' +
          'background:var(--lp-bg);color:var(--lp-text);font-size:13px;cursor:pointer;">' +
          'Tekrar Dene' +
        '</button>' +
      '</div>';
  }

  // ── Render ─────────────────────────────────────────
  function renderApp() {
    var app = document.getElementById('loyalty-app');
    if (!app) return;

    // İstatistik değerleri
    setText('lp-total-earned',   fmtPoints(loyaltyData.total_earned_points));
    setText('lp-total-spent',    fmtPoints(loyaltyData.total_spent_points));
    setText('lp-current-points', fmtPoints(loyaltyData.current_points));

    // Dönüştür butonu
    var convertBtn = document.getElementById('lp-open-convert');
    if (convertBtn) {
      if ((loyaltyData.current_points || 0) >= 1) {
        convertBtn.removeAttribute('disabled');
        convertBtn.removeAttribute('aria-disabled');
      } else {
        convertBtn.setAttribute('disabled', '');
        convertBtn.setAttribute('aria-disabled', 'true');
      }
    }

    renderCoupons();
  }

  function setText(id, text) {
    var el = document.getElementById(id);
    if (!el) return;
    el.textContent = text;
    el.classList.remove('lp-skeleton', 'lp-skeleton--value');
  }

  // ── Geçmiş Kuponlarım ──────────────────────────────
  function renderCoupons() {
    var list = document.getElementById('lp-coupons-list');
    if (!list) return;

    var now = Date.now();
    var coupons = loyaltyData.coupons || loyaltyData.active_coupons || [];

    if (coupons.length === 0) {
      var emptyText = list.dataset.empty ||
        'Henüz aktif indirim kodunuz yok. Puanlarınızı kupona dönüştürerek alışverişlerinizde kullanabilirsiniz.';
      list.innerHTML = '<p class="lp-empty">' + escHtml(emptyText) + '</p>';
      return;
    }

    list.innerHTML = coupons
      .map(function (c) {
        var expired = new Date(c.expires_at).getTime() <= now;
        var statusClass, statusLabel;
        if (c.used) {
          statusClass = 'lp-status--used';
          statusLabel = 'Kullanıldı';
        } else if (expired) {
          statusClass = 'lp-status--expired';
          statusLabel = 'Süresi Doldu';
        } else {
          statusClass = 'lp-status--active';
          statusLabel = 'Aktif';
        }

        return (
          '<div class="lp-coupon-row">' +
            '<div class="lp-coupon-points">' + medalIcon() + fmtPoints(c.value) + '</div>' +
            '<div class="lp-coupon-mid">' +
              '<span class="lp-coupon-code">' + escHtml(c.code) + '</span>' +
              '<span>Kupon Tutarı: <strong>' + fmtCurrency(c.value) + '</strong></span>' +
            '</div>' +
            '<div class="lp-coupon-date">' + infoIcon() + 'Oluşturulma Tarihi: ' + fmtDate(c.created_at) + '</div>' +
            '<span class="lp-coupon-status ' + statusClass + '">' +
              (statusLabel === 'Aktif' ? checkIcon() : '') +
              statusLabel +
            '</span>' +
          '</div>'
        );
      })
      .join('');
  }

  // ── Modal ──────────────────────────────────────────
  var modal = document.getElementById('lp-modal');

  document.getElementById('lp-open-convert').addEventListener('click', function () {
    var pts = Math.floor(loyaltyData.current_points || 0);
    document.getElementById('lp-modal-balance').textContent = fmtPoints(pts);
    var input = document.getElementById('lp-convert-amount');
    input.max = pts;
    input.value = pts;
    modal.hidden = false;
    input.focus();
  });

  document.getElementById('lp-modal-cancel').addEventListener('click', closeModal);
  document.getElementById('lp-modal-backdrop').addEventListener('click', closeModal);

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && !modal.hidden) closeModal();
  });

  function closeModal() {
    modal.hidden = true;
  }

  document.getElementById('lp-modal-confirm').addEventListener('click', function () {
    var amount = parseInt(document.getElementById('lp-convert-amount').value, 10);
    if (!amount || amount < 1) {
      showToast('Lütfen geçerli bir miktar girin.', 'error');
      return;
    }
    if (amount > Math.floor(loyaltyData.current_points || 0)) {
      showToast('Yeterli puanınız bulunmamaktadır.', 'error');
      return;
    }

    var confirmBtn = document.getElementById('lp-modal-confirm');
    confirmBtn.disabled = true;
    confirmBtn.textContent = 'Oluşturuluyor...';

    fetch(FETCH_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ amount: amount }),
    })
      .then(function (r) { return r.json(); })
      .then(function (json) {
        if (json.success) {
          closeModal();
          showGeneratedCode(json.coupon.code);
          loyaltyData = null;
          fetchData().then(function () {
            showToast('Kupon oluşturuldu: ' + json.coupon.code, 'success');
          });
        } else {
          showToast(json.error || 'Bir hata oluştu.', 'error');
        }
      })
      .catch(function () { showToast('Bağlantı hatası.', 'error'); })
      .finally(function () {
        confirmBtn.disabled = false;
        confirmBtn.textContent = CONFIRM_LABEL;
      });
  });

  // ── Oluşturulan Kod Gösterimi ──────────────────────
  function showGeneratedCode(code) {
    var display = document.getElementById('lp-code-display');
    var valueEl = document.getElementById('lp-code-display-value');
    var copyBtn = document.getElementById('lp-copy-generated');
    if (!display || !valueEl || !copyBtn) return;

    valueEl.textContent = code;
    display.classList.add('lp-code-display--filled');
    copyBtn.hidden = false;
    copyBtn.dataset.code = code;
  }

  document.getElementById('lp-copy-generated').addEventListener('click', function (e) {
    var btn = e.currentTarget;
    var code = btn.dataset.code;
    if (!code) return;
    copyToClipboard(code, btn);
  });

  function copyToClipboard(code, btn) {
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(code).then(function () { markCopied(btn); });
    } else {
      var ta = document.createElement('textarea');
      ta.value = code;
      ta.style.position = 'fixed';
      ta.style.opacity = '0';
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      ta.remove();
      markCopied(btn);
    }
  }

  function markCopied(btn) {
    var original = btn.innerHTML;
    btn.classList.add('lp-copy-btn--copied');
    btn.innerHTML = checkIcon();
    setTimeout(function () {
      btn.classList.remove('lp-copy-btn--copied');
      btn.innerHTML = original;
    }, 2000);
    showToast('Kupon kodu kopyalandı!', 'success');
  }

  // ── SVG İkonlar ────────────────────────────────────
  function copyIcon() {
    return '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
  }
  function checkIcon() {
    return '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
  }
  function infoIcon() {
    return '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>';
  }
  function medalIcon() {
    return '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.5 13.5 17 22l-5-3-5 3 1.5-8.5"/></svg>';
  }

  function escHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  // ── Başlat ─────────────────────────────────────────
  //
  // Strateji:
  //  1. Liquid'den gelen __LP__ verisiyle anında render et (proxy gerekmez)
  //  2. Arka planda proxy'ye sessiz sync isteği gönder (siparişleri kredilendirmek için)
  //     Bu istek başarısız olsa bile sayfa çalışmaya devam eder.

  var DEFAULT_DATA = {
    total_earned_points: 0,
    total_spent_points: 0,
    current_points: 0,
    coupons: [],
    active_coupons: [],
  };

  function initFromLiquid() {
    try {
      loyaltyData = window.__LP__ || DEFAULT_DATA;
      loyaltyData.coupons = loyaltyData.coupons || loyaltyData.active_coupons || [];
    } catch (e) {
      loyaltyData = DEFAULT_DATA;
    }
    renderApp();
  }

  function syncInBackground() {
    fetch(FETCH_URL, {
      headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
    })
      .then(function (r) {
        if (!r.ok) return null;
        var ct = r.headers.get('content-type') || '';
        if (!ct.includes('application/json')) return null;
        return r.json();
      })
      .then(function (json) {
        if (json && json.success && json.data) {
          loyaltyData = json.data;
          renderApp(); // Güncellenen veriyle sessizce yenile
        }
      })
      .catch(function (err) {
        // Arka plan sync başarısız — sorun değil, Liquid verisi zaten gösteriliyor
        console.warn('[Loyalty] Background sync failed (harmless):', err.message);
      });
  }

  // Önce Liquid verisini göster (anında, 0ms gecikme)
  initFromLiquid();

  // Sonra arka planda sync dene (yeni siparişleri kredilendirmek için)
  syncInBackground();
})();
</script>

